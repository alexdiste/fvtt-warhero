{
    "id": "fvtt-warhero",
    "title": "Warhero RPG",
    "description": "Warhero RPG system for FoundryVTT",
    "version": "14.57",
    "compatibility": {
        "minimum": "13",
        "verified": "14"
    },
    "manifest": "https://github.com/alexdiste/fvtt-warhero/releases/download/v14.57/system.json",
    "download": "https://github.com/alexdiste/fvtt-warhero/releases/download/v14.57/fvtt-warhero-14.57.zip",
    "authors": [
        {
            "name": "AlexDiste"
        }
    ],
    "esmodules": [
        "modules/warhero-main.js"
    ],
    "styles": [
        "styles/simple.css"
    ],
    "flags": {
        "hotReload": {
            "extensions": [
                "css",
                "html",
                "hbs",
                "json"
            ],
            "paths": [
                "./",
                "templates",
                "styles",
                "lang/en.json",
                "lang/it.json"
            ]
        }
    },
    "grid": {
        "distance": 1,
        "units": "m"
    },
    "languages": [
        {
            "lang": "en",
            "name": "English",
            "path": "lang/en.json"
        },
        {
            "lang": "it",
            "name": "Italian",
            "path": "lang/it.json"
        }
    ],
    "primaryTokenAttribute": "attributes.hp",
    "secondaryTokenAttribute": "attributes.mana",
    "socket": true,
    "documentTypes": {
        "Actor": {
            "character": {
