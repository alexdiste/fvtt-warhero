<section class="tab-content-scrollable tab sheet-body character-{{ tab.id }} {{ tab.cssClass }}" data-tab="{{ tab.id }}"
  data-group="{{ tab.group }}">
  {{!-- Skills Tab --}}
  <div>
    <div class="flexcol">
      <button type="button" class="actor-sheet-button" data-action="reset-skill-use">{{localize "WH.ui.resetSkillUse"}}</button>
    </div>

    <div class="flexrow equipment-filter-bar">
      <div class="item-filter-search-wrapper">
        <input type="text" class="item-filter-search" placeholder="{{localize "WH.ui.searchitems"}}">
        <i class="fa-solid fa-times item-filter-clear"></i>
      </div>
      <select class="item-filter-category">
        <option value="">{{localize "WH.ui.filterall"}}</option>
        <option value="race">{{localize "WH.ui.raceSkills"}}</option>
        <option value="class">{{localize "WH.ui.classSkills"}}</option>
        <option value="level">{{localize "WH.ui.skills"}}</option>
      </select>
      <label class="item-filter-label"><input type="checkbox" class="item-filter-passive"> {{localize "WH.ui.hidepassive"}}</label>
    </div>

    <div class="flexcol">

      <div>
        <ul class="stat-list alternate-list">
          <li class="item flexrow list-item items-title-bg">
            <span class="item-name-label-header-long actor-skill-title1">
              <h3><label class="items-title-text">{{localize "WH.ui.raceSkills"}}</label></h3>
            </span>
            <span class="item-field-label-medium">
              <label class="short-label">{{localize "WH.ui.level"}}</label>
            </span>
            <span class="item-field-label-medium skill-current-use">
              <label class="short-label">{{localize "WH.ui.currentuse"}}</label>
            </span>
            <span class="item-field-label-medium">
              <label class="short-label">{{localize "WH.ui.maxuse"}}</label>
            </span>
            <div class="item-filler">&nbsp;</div>
          </li>
          {{#each raceSkills as |skill key|}}
          <li class="item flexrow list-item list-item-shadow" data-item-id="{{skill._id}}" data-item-name="{{skill.name}}" data-filter-passive="{{skill.system.unlimited}}" data-filter-category="race">
            <a class="item-edit item-name-img" data-action="item-edit" title="Edit Item"><img
                class="sheet-competence-img" src="{{skill.img}}" /></a>
            <span class="item-name-label-long">{{skill.name}}</a></span>

            <span class="item-field-label-medium">{{skill.system.acquiredatlevel}}</span>

            {{#if skill.system.unlimited}}
            <span class="item-field-label-medium skill-current-use">N/A</span>
            <span class="item-field-label-medium">N/A</span>
            {{else}}
            <span class="item-field-label-medium skill-current-use">{{skill.system.currentuse}}
              (<a class="skill-use-minus plus-minus-button" data-action="skill-minus"><i class="fa-solid fa-circle-minus"></i></a>/<a
                class="skill-use-plus plus-minus-button" data-action="skill-plus"><i class="fa-solid fa-circle-plus"></i></a>)
            </span>
            <span class="item-field-label-medium">{{skill.system.maxuse}}</span>
            {{/if}}

            <div class="item-filler">&nbsp;</div>
            <div class="item-controls item-controls-fixed">
              <a class="item-control" data-action="skill-description-chat" title="{{localize "WH.ui.skillChat"}}"><i
                  class="fas fa-comment"></i></a>
              <a class="item-control item-delete" data-action="item-delete" title="Delete Item"><i
                  class="fas fa-trash"></i></a>
            </div>
          </li>
          {{/each}}
        </ul>
      </div>

      <div>
        <ul class="stat-list alternate-list">
          <li class="item flexrow list-item items-title-bg">
            <span class="item-name-label-header-long actor-skill-title1">
              <h3><label class="items-title-text">{{localize "WH.ui.classSkills"}}</label></h3>
            </span>
            <span class="item-field-label-medium">
              <label class="short-label">{{localize "WH.ui.level"}}</label>
            </span>
            <span class="item-field-label-medium skill-current-use">
              <label class="short-label">{{localize "WH.ui.currentuse"}}</label>
            </span>
            <span class="item-field-label-medium">
              <label class="short-label">{{localize "WH.ui.maxuse"}}</label>
            </span>
            <div class="item-filler">&nbsp;</div>
          </li>
          {{#each classSkills as |skill key|}}
          <li class="item flexrow list-item list-item-shadow" data-item-id="{{skill._id}}" data-item-name="{{skill.name}}" data-filter-passive="{{skill.system.unlimited}}" data-filter-category="class">
            <a class="item-edit item-name-img" data-action="item-edit" title="Edit Item"><img
                class="sheet-competence-img" src="{{skill.img}}" /></a>
            <span class="item-name-label-long">{{skill.name}}</a></span>

            <span class="item-field-label-medium">{{skill.system.acquiredatlevel}}</span>
            {{#if skill.system.unlimited}}
            <span class="item-field-label-medium skill-current-use">N/A</span>
            <span class="item-field-label-medium">N/A</span>
            {{else}}
            <span class="item-field-label-medium skill-current-use">{{skill.system.currentuse}}
              (<a class="skill-use-minus plus-minus-button" data-action="skill-minus"><i class="fa-solid fa-circle-minus"></i></a>/<a
                class="skill-use-plus plus-minus-button" data-action="skill-plus"><i class="fa-solid fa-circle-plus"></i></a>)
            </span>
            <span class="item-field-label-medium">{{skill.system.maxuse}}</span>
            {{/if}}

            <div class="item-filler">&nbsp;</div>
            <div class="item-controls item-controls-fixed">
              <a class="item-control" data-action="skill-description-chat" title="{{localize "WH.ui.skillChat"}}"><i
                  class="fas fa-comment"></i></a>
              <a class="item-control item-delete" data-action="item-delete" title="Delete Item"><i
                  class="fas fa-trash"></i></a>
            </div>
          </li>
          {{/each}}
        </ul>
      </div>

      <div>
        <ul class="stat-list alternate-list">
          <li class="item flexrow list-item items-title-bg">
            <span class="item-name-label-header-long actor-skill-title1">
              <h3><label class="items-title-text">{{localize "WH.ui.skills"}}</label></h3>
            </span>
            <span class="item-field-label-medium">
              <label class="short-label">{{localize "WH.ui.level"}}</label>
            </span>
            <span class="item-field-label-medium skill-current-use">
              <label class="short-label">{{localize "WH.ui.currentuse"}}</label>
            </span>
            <span class="item-field-label-medium">
              <label class="short-label">{{localize "WH.ui.maxuse"}}</label>
            </span>
            <div class="item-filler">&nbsp;</div>
          </li>
          {{#each skills as |skill key|}}
          <li class="item flexrow list-item list-item-shadow" data-item-id="{{skill._id}}" data-item-name="{{skill.name}}" data-filter-passive="{{skill.system.unlimited}}" data-filter-category="level">
            <a class="item-edit item-name-img" data-action="item-edit" title="Edit Item"><img
                class="sheet-competence-img" src="{{skill.img}}" /></a>
            <span class="item-name-label-long">{{skill.name}}</span>

            <span class="item-field-label-medium">{{skill.system.acquiredatlevel}}</span>

            {{#if skill.system.unlimited}}
            <span class="item-field-label-medium skill-current-use">N/A</span>
            <span class="item-field-label-medium">N/A</span>
            {{else}}
            <span class="item-field-label-medium skill-current-use">{{skill.system.currentuse}}
              (<a class="skill-use-minus plus-minus-button" data-action="skill-minus"><i class="fa-solid fa-circle-minus"></i></a>/<a
                class="skill-use-plus plus-minus-button" data-action="skill-plus"><i class="fa-solid fa-circle-plus"></i></a>)
            </span>
            <span class="item-field-label-medium">{{skill.system.maxuse}}</span>
            {{/if}}

            <div class="item-filler">&nbsp;</div>
            <div class="item-controls item-controls-fixed">
              <a class="item-control" data-action="skill-description-chat" title="{{localize "WH.ui.skillChat"}}"><i
                  class="fas fa-comment"></i></a>
              <a class="item-control item-delete" data-action="item-delete" title="Delete Item"><i
                  class="fas fa-trash"></i></a>
            </div>
          </li>
          {{/each}}
        </ul>
      </div>

      <div>
        <ul class="stat-list alternate-list">
          <li class="item flexrow list-item items-title-bg">
            <span class="item-name-label-header-long actor-skill-title1">
              <h3><label class="items-title-text">{{localize "WH.ui.conditions"}}</label></h3>
            </span>
            <span class="item-field-label-medium condition-effect-label">
              <label class="short-label">{{localize "WH.ui.effect"}}</label>
            </span>
            <div class="item-filler">&nbsp;</div>
          </li>
          {{#each conditions as |cond key|}}
          <li class="item flexrow list-item list-item-shadow" data-item-id="{{cond._id}}">
            <a class="item-edit item-name-img" data-action="item-edit" title="Edit Item"><img
                class="sheet-competence-img" src="{{cond.img}}" /></a>
            <span class="item-name-label-long">{{cond.name}}</span>

            <span class="item-field-label-medium condition-effect-label">{{cond.system.shortdescription}}</span>

            <div class="item-filler">&nbsp;</div>
            <div class="item-controls item-controls-fixed">
              <a class="item-control item-delete" data-action="item-delete" title="Delete Item"><i
                  class="fas fa-trash"></i></a>
            </div>
          </li>
          {{/each}}
        </ul>
      </div>
    </div>
  </div>
</section>
