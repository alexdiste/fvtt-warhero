<section
  class="tab tab-content-scrollable sheet-body party-{{tab.id}}
    {{tab.cssClass}}"
  data-group="sheet"
  data-tab="{{tab.id}}"
>

  <div>
    <div class="flexrow" style="gap:0.75rem; align-items:center; margin-bottom:1rem;">
      <label class="item-field-label-medium" for="party-founded">{{localize "WH.ui.founded"}}:</label>
      <input id="party-founded" type="number" class="item-field-label-medium" name="system.biodata.founded" value="{{system.biodata.founded}}" />
    </div>
    <hr />
    <h3>{{localize "WH.ui.background"}} : </h3>
    <div class="editor">
      {{formInput
        systemFields.biodata.fields.description
        enriched=enrichedDescription
        value=system.biodata.description
        name="system.biodata.description"
        toggled=true
      }}
    </div>
    <hr />
    <h3>{{localize "WH.ui.notes"}} : </h3>
    <div class="editor">
      {{formInput
        systemFields.biodata.fields.notes
        enriched=enrichedNotes
        value=system.biodata.notes
        name="system.biodata.notes"
        toggled=true
      }}
    </div>
    {{#if isGM}}
    <hr />
    <h3>{{localize "WH.ui.gmnotes"}} :</h3>
    <div class="editor">
      {{formInput
        systemFields.biodata.fields.gmnotes
        enriched=enrichedGmNotes
        value=system.biodata.gmnotes
        name="system.biodata.gmnotes"
        toggled=true
      }}
    </div>
    {{/if}}
  </div>

</section>