<section
  class="tab tab-content-scrollable sheet-body party-{{tab.id}} {{tab.cssClass}}"
  data-group="sheet"
  data-tab="{{tab.id}}"
>
  <strong>{{localize "WH.ui.totalmoney"}}:</strong> {{memberMoney}}<br><br>
  

  <div class="party-members-section">
    <h3>{{localize "WH.ui.members"}}</h3>
    {{#if members.length}}
    <ul class="stat-list alternate-list">
      {{#each members as |member|}}
      <li class="item flexrow list-item list-item-shadow" data-member-uuid="{{member.uuid}}">
        <a class="item-edit item-name-img" data-action="openMember" data-member-uuid="{{member.uuid}}" title="{{member.name}}">
          <img class="sheet-competence-img" src="{{member.img}}" />
        </a>
        <span class="item-name-label-long"><a class="open-member-link" data-action="openMember" data-member-uuid="{{member.uuid}}">{{member.name}}</a></span>
        <div class="item-filler">&nbsp;</div>
        <div class="item-controls item-controls-fixed">
          <a class="item-control item-delete" data-action="removeMember" data-member-uuid="{{member.uuid}}" title="{{localize "WH.ui.remove"}}"><i class="fas fa-trash"></i></a>
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p>{{localize "WH.ui.noMembers"}}</p>
    {{/if}}
  </div>

  <div class="party-relations-section">
    <h3>{{localize "WH.ui.relations"}}</h3>
    {{#if relations.length}}
    <ul class="stat-list alternate-list">
      {{#each relations as |relation|}}
      <li class="item flexrow list-item list-item-shadow" data-member-uuid="{{relation.uuid}}">
        <a class="item-edit item-name-img" data-action="openMember" data-member-uuid="{{relation.uuid}}" title="{{relation.name}}">
          <img class="sheet-competence-img" src="{{relation.img}}" />
        </a>
        <span class="item-name-label-long"><a class="open-member-link" data-action="openMember" data-member-uuid="{{relation.uuid}}">{{relation.name}}</a></span>
        <div class="relation-actions" style="display:flex; gap:0.35rem; align-items:center;">
          <a class="actor-relation-option {{#if (eq relation.relation "neutral")}}active{{/if}}" data-action="setRelation" data-member-uuid="{{relation.uuid}}" data-relation="neutral">{{localize "WH.ui.neutral"}}</a>
          <a class="actor-relation-option {{#if (eq relation.relation "allied")}}active{{/if}}" data-action="setRelation" data-member-uuid="{{relation.uuid}}" data-relation="allied">{{localize "WH.ui.allied"}}</a>
          <a class="actor-relation-option {{#if (eq relation.relation "hostile")}}active{{/if}}" data-action="setRelation" data-member-uuid="{{relation.uuid}}" data-relation="hostile">{{localize "WH.ui.hostile"}}</a>
        </div>
        <div class="item-filler">&nbsp;</div>
        <div class="item-controls item-controls-fixed">
          <a class="item-control item-delete" data-action="removeRelation" data-member-uuid="{{relation.uuid}}" title="{{localize "WH.ui.remove"}}"><i class="fas fa-trash"></i></a>
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p>{{localize "WH.ui.noRelations"}}</p>
    {{/if}}
  </div>

  {{#if isGM}}
  <div class="party-gm-notes">
    <h3>{{localize "WH.ui.gmnotes"}} :</h3>
    <div class="editor">
      {{formInput
        systemFields.biodata.fields.gmnotes
        enriched=enrichedGmNotes
        value=system.biodata.gmnotes
        name="system.biodata.gmnotes"
        toggled=true
      }}
    </div>
  </div>
  {{/if}}
</section>
